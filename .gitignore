# Go 项目忽略文件

# 编译生成的二进制文件
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试二进制文件，使用 `go test -c` 生成
*.test

# 输出文件
*.out

# Go 工作区文件
go.work
go.work.sum

# 依赖目录（如果使用 vendor 模式）
vendor/

# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 日志文件
*.log

# 临时文件夹
Temp/

# 环境变量文件
.env
.env.local

# 构建输出目录
bin/
dist/
build/
